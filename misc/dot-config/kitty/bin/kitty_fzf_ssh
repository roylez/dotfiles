#!/usr/bin/env zsh
#
unset FZF_DEFAULT_OPTS

local config=~/.ssh/config

awk '/^Host .*$/ {for(i=2;i<=NF;i++){ if($i !~ /[*?]/) print $i }}' $config | sort -u  |\
  fzf -q "$*" \
  --prompt 'SSH TO -> ' \
  --layout reverse \
  --preview-window default \
  --preview "awk -v RS= '/^Host (.* )*{1}/' ${config}" \
  --header "[ENTER] connect | [C-O] edit config" \
  --bind "enter:become(kitten @ set-window-title -m state:self '@{1}'; ssh {1})" \
  --bind "ctrl-o:execute(${EDITOR} ${config})"
