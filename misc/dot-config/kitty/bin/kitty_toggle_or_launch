#!/bin/bash
#

ARGS=()
while [[ "$#" -gt 0 ]]; do case $1 in
    --tab)    tab_index=$2 ;      shift 2 ;;
    --title)  title="$2"   ;      shift 2 ;;
    --color)  color="--color $2"; shift 2 ;;
    *)        ARGS+=("$1") ;      shift ;;
esac; done

set -- "${ARGS[@]}"

current_title=$(kitty @ ls -t recent:0 |jq -r '.[0].tabs[0].title')

if [[ $current_title = "$title" ]]; then
  exit 0
elif (kitten @ ls -m title:${title} &>/dev/null); then
  echo kitten @ focus-window -m title:${title}
  kitten @ focus-window -m title:${title}
elif [[ -n $tab_index ]]; then
  kitten @ launch ${color} -m index:$tab_index --title=${title} "${ARGS[@]}"
  kitten @ focus-window -m title:${title}
else
  kitten @ launch ${color} --type=tab --title=${title} "${ARGS[@]}"
fi
