{
  "statusLine": {
    "type": "command",
    "command": "/home/roy/.claude/statusline-command.sh"
  },
  "env": {
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "mcp__serena__*",
      "mcp__plugin_serena_serena__*",
      "mcp__context7__*",
      "mcp__mnemosyne__*",
      "Skill(superpowers:*)",
      "Skill(distill)",
      "WebSearch",
      "Bash(elixir:*)",
      "Bash(mix *)",
      "Bash(cat:*)",
      "Bash(git:*)",
      "Bash(jj:*)",
      "Bash(timeout:*)",
      "Bash(grep:*)",
      "Bash(docker build:*)",
      "Bash(docker images:*)",
      "Read(~/.claude/*)",
      "Read(/home/roy/.claude/*)",
      "Edit(~/.claude/*)",
      "Edit(/home/roy/.claude/*)",
      "Write(~/.claude/*)",
      "Write(/home/roy/.claude/*)",
      "Bash(ls ~/.claude/*)",
      "Bash(ls /home/roy/.claude/*)",
      "Bash(mkdir ~/.claude/*)",
      "Bash(mkdir -p ~/.claude/*)",
      "Bash(mkdir /home/roy/.claude/*)",
      "Bash(mkdir -p /home/roy/.claude/*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/scripts/hook-handle-use.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/scripts/hook-handle-rename.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "agent",
            "prompt": "You are a session distillation filter. Review the conversation so far. If this session produced useful knowledge (preferences, decisions, architectural insights, gotchas, corrections, or reusable workflows) AND has had at least 5 substantive exchanges, run /distill to persist them to long-term memory via Mnemosyne. If the session was trivial (simple questions, quick fixes, no new knowledge worth preserving), return {\"ok\": true} without distilling.",
            "model": "sonnet",
            "timeout": 180
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/roy/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Context is about to be compacted. Before it is lost, run /distill to extract and persist any useful knowledge from this session to long-term memory via Mnemosyne.",
            "model": "sonnet",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "serena@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "mem0-plugins": {
      "source": {
        "source": "github",
        "repo": "mem0ai/mem0"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowUnixSockets": [
        "/var/run/docker.sock"
      ],
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "docker"
    ]
  }
}
